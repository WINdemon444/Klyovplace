<!DOCTYPE html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <title><%= product.name %> - KlyovPlace</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%- include('partials/header') %>

    <div class="container product-page">
      <a href="/catalog" class="back-link">← Назад до каталогу</a>

      <div class="product-details-box">
        <div class="product-image-large">
          <img src="<%= product.image %>" alt="<%= product.name %>" />
        </div>

        <div class="product-info-large">
          <span class="category-tag"><%= product.category %></span>
          <h1><%= product.name %></h1>
          <p class="price-large"><%= product.price %> грн</p>

          <div class="description-box">
            <h3>Опис товару:</h3>
            <p><%= product.description %></p>
          </div>
          <% const isInCart = cart.some(item => item.id === product.id); %>

          <% if (isInCart) { %>
              <button class="btn-add-cart" disabled style="background: #bdc3c7; cursor: not-allowed; box-shadow: none;">
                  Вже у кошику ✔️
              </button>
          <% } else { %>
              <form action="/add_to_cart" method="POST">
                  <input type="hidden" name="productId" value="<%= product.id %>">
                  <button type="submit" class="btn-add-cart">Додати в кошик 🛒</button>
              </form>
          <% } %>
        </div>
      </div>
    </div>
  </body>
</html>
