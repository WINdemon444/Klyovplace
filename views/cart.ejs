<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Мій кошик - KlyovPlace</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="container cart-page">
        <h1>Твій кошик 🛒</h1>

        <!-- Перевіряємо, чи порожній кошик -->
        <% if(cartItems.length === 0) { %>
            <div class="empty-cart">
                <p>Тут поки що порожньо. Час знайти круті снасті!</p>
                <a href="/catalog" class="btn">Перейти в каталог</a>
            </div>
        <% } else { %>
            <!-- Якщо товари є, виводимо список -->
            <div class="cart-list">
                <% cartItems.forEach(function(item) { %>
                    <div class="cart-item">
                        <img src="<%= item.image %>" alt="<%= item.name %>">
                        <div class="cart-item-info">
                            <h3><%= item.name %></h3>
                            <p class="text-muted"><%= item.category %></p>
                        </div>
                        <div class="cart-item-price">
                            <%= item.price %> грн
                        </div>
                        <form action="/remove-from-cart" method="POST" class="remove-form">
                            <input type="hidden" name="productId" value="<%= item.id %>"/>
                            <button type="submit" class="btn-remove" title="Видалити товар">❌</button>
                        </form>
                    </div>
                <% }); %>
            </div>

            <!-- Блок із загальною сумою -->
          <div class="cart-summary">          
            <h2>Разом: <span class="highlight-price"><%= totalSum %> грн</span></h2>
            
            <div class="cart-actions" style="display: flex; gap: 15px; align-items: center;">
                <form action="/clear_cart" method="POST">
                    <button type="submit" class="btn-clear-all">Очистити кошик 🗑️</button>
                </form>

                <button class="btn-checkout">Оформити замовлення</button>
            </div>
        </div>
        <% } %>
    </div>
</body>
</html>