<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Оформлення замовлення - KlyovPlace</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <div class="container checkout-page">
        <h1>Оформлення замовлення 📑</h1>

        <div class="checkout-container">
            <div class="checkout-form-box">
                <h2>Контактні дані</h2>
                
                <form action="https://formspree.io/f/mrevoada" method="POST">
                    <div class="form-group">
                        <label for="name">Ваше ім'я та прізвище:</label>
                        <input type="text" id="name" name="Клієнт" required>
                    </div>
                    
                    <div class="form-group">
                            <label for="email">Електронна пошта:</label>
                            <input type="email" id="email" name="email" required placeholder="example@mail.com">
                        </div>

                    <div class="form-group">
                        <label for="phone">Номер телефону:</label>
                        <input type="tel" id="phone" name="Телефон" required>
                    </div>

                    <div class="form-group">
                        <label for="address">Адреса доставки:</label>
                        <input type="text" id="address" name="Адреса" required>
                    </div>

                                    <input type="hidden" name="Замовлені товари" value="<%= cartItems.map(item => item.name).join(', ') %>">
                    <input type="hidden" name="Сума" value="<%= totalSum %> грн">

                    <button type="submit" class="btn-confirm">Підтвердити замовлення 🎣</button>
                </form>
            </div>

            <div class="checkout-summary-box">
                <h2>Ваше замовлення</h2>
                <% cartItems.forEach(function(item) { %>
                    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #ccc; padding: 5px 0;">
                        <span><%= item.name %></span>
                        <strong><%= item.price %> грн</strong>
                    </div>
                <% }); %>
                <h3 style="text-align: right; color: #05c46b;">Разом: <%= totalSum %> грн</h3>
            </div>
        </div>
    </div>
</body>
</html>